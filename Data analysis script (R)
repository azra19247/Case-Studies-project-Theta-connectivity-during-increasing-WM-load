#=============================================================
#STEP 1: PREPARATION
#=============================================================

#1. load packages
library(lme4)
library(lmerTest)
library(ggplot2)
library(dplyr)
library(car)

#2. Load your data
df <- read.csv("/Users/miralombaert/Desktop/master2/casestudies/wpli_master_dataframe.csv")
head(df)
str(df)

#3. set breakpoint

  #Plot as a Grouped Bar Chart (Raw Counts): this figure shows the count of errors versus the count of correct retrievals
  #this way we can use a data-based approach to choose the best break point: 

ggplot(df[df$condition == "memory", ], aes(x = factor(position), fill = outcome)) +
  geom_bar(position = "dodge") +
  labs(
    title = "Outcome Counts by Position",
    x = "Position",
    y = "Count",
    fill = "Outcome"
  ) +
  theme_minimal()

  #set break point, data justified: 
  #for the data justification, we will look at the plot and take the BP
  #where the correct count first dropped below the error count
BP <- 6 

#4.piecewise predictors

#define two re-parametrized predictors and add to the dataframe: together they create a hinge at the BP
  # Load 1: increases from 1 to BP, then stays flat
df$load1 <- ifelse(df$position <= BP, df$position, BP)
  # Load 2: 0 before BP, then increases after the BP
df$load2 <- ifelse(df$position > BP, df$position - BP, 0)

# Check how this looks in the dataframe
head(df,13)

